<?xml version="1.0" encoding="utf-8"?>
<!--
    Marco guía para el escáner: solo las 4 esquinas en cian,
    sin bordes completos (da el efecto de visor moderno).
    Se implementa como un simple borde redondeado semitransparente.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Borde exterior cian semitransparente -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke
                android:width="2dp"
                android:color="#8000BCD4" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- Esquinas internas en cian sólido (efecto visor) -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="230dp"
        android:bottom="150dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke android:width="3dp" android:color="#00BCD4" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <item
        android:left="230dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="150dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke android:width="3dp" android:color="#00BCD4" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
