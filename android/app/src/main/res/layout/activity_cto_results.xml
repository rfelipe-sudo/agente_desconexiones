<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Image Card -->
        <LinearLayout
            android:id="@+id/imageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp" />

            <ImageView
                android:id="@+id/peloImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <TextView
                android:id="@+id/imageErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#C62828"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Ports Card -->
        <LinearLayout
            android:id="@+id/portsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tableTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado de Puertos"
                android:textColor="#2C3E50"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TableLayout
                android:id="@+id/portTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:stretchColumns="*" />

            <TextView
                android:id="@+id/tableErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#C62828"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Refresh Button -->
            <Button
                android:id="@+id/refreshButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Refrescar niveles"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="@drawable/button_green"
                android:visibility="gone" />

            <TextView
                android:id="@+id/lastUpdatedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#999999"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Reescanear Button -->
        <Button
            android:id="@+id/reescanearButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Reescanear"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/button_primary" />

        <!-- Volver al inicio Button -->
        <Button
            android:id="@+id/volverInicioButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="48dp"
            android:text="Volver al inicio"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/button_green" />

    </LinearLayout>
</ScrollView>
