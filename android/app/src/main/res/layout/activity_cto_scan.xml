<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Cámara full-screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:implementationMode="performance"
        app:scaleType="fillCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay de detección (cuadros IA) -->
    <com.karimpichara.turingandroid.DetectionOverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Degradado negro → transparente (arriba) -->
    <View
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:background="@drawable/gradient_top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón cerrar circular (esquina superior izquierda) -->
    <ImageButton
        android:id="@+id/closeButton"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="38dp"
        android:background="@drawable/circle_button_bg"
        android:src="@drawable/ic_close_white"
        android:contentDescription="Cerrar"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Marco guía estilo "marco fotográfico" — ocupa ~88% del ancho con
         relación 4:3 y se ubica casi al borde de la pantalla. -->
    <View
        android:id="@+id/scanFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/scan_frame_border"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.92"
        app:layout_constraintDimensionRatio="W,4:3"
        app:layout_constraintVertical_bias="0.42" />

    <!-- 4 esquinas L (vector) constreñidas a las esquinas de scanFrame -->
    <ImageView
        android:id="@+id/scanCornerTL"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/scan_corner_tl"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="@id/scanFrame"
        app:layout_constraintStart_toStartOf="@id/scanFrame" />
    <ImageView
        android:id="@+id/scanCornerTR"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/scan_corner_tr"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="@id/scanFrame"
        app:layout_constraintEnd_toEndOf="@id/scanFrame" />
    <ImageView
        android:id="@+id/scanCornerBL"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/scan_corner_bl"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="@id/scanFrame"
        app:layout_constraintStart_toStartOf="@id/scanFrame" />
    <ImageView
        android:id="@+id/scanCornerBR"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/scan_corner_br"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="@id/scanFrame"
        app:layout_constraintEnd_toEndOf="@id/scanFrame" />

    <!-- Texto "Escaneando..." animado -->
    <TextView
        android:id="@+id/scanningText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escaneando..."
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:shadowColor="#CC000000"
        android:shadowRadius="8"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/scanFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/statusText"
        app:layout_constraintVertical_bias="0.35" />

    <!-- Degradado transparente → negro (abajo) -->
    <View
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@drawable/gradient_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Volver al inicio (parte inferior, sobre el status) -->
    <Button
        android:id="@+id/volverInicioScanButton"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="52dp"
        android:text="Volver al inicio"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/button_green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Estado del modelo (esquina inferior, texto pequeño) -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:text="@string/cto_loading_models"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/volverInicioScanButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- RUT oculto (se mantiene el id por compatibilidad con el código Kotlin) -->
    <TextView
        android:id="@+id/rutValue"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
